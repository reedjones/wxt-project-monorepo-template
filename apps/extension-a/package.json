{
  "name": "extension-a",
  "version": "0.0.1",
  "private": true,
  "description": "Extension A - WXT browser extension",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "typecheck": "wxt prepare && tsc --noEmit",
    "lint": "eslint entrypoints --ext .ts,.tsx"
  },
  "dependencies": {
    "@wxt-monorepo/shared": "workspace:*",
    "@wxt-monorepo/ui": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@wxt-dev/module-react": "^1.1.5",
    "@wxt-monorepo/config": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "wxt": "^0.20.3"
  }
}
